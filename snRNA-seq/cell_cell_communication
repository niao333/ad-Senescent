# ==============================================================================
# 1. 定义通用绘图函数 (核心逻辑)
#    这个函数会自动完成计算信息流、计算LogFC、筛选通路、绘图的全过程
# ==============================================================================
plot_ageing_specific_flow <- function(cellchat, cell_type_name, normal_ident, senescent_ident) {
  
  message(paste("正在处理:", cell_type_name, "..."))
  
  # 提取所有通路
  pathways <- cellchat@netP$pathways
  
  # --- 1.1 计算 Source (作为发送者) 的信息流 ---
  flow_source_senescent <- sapply(pathways, function(p) {
    net <- subsetCommunication(cellchat, sources.use = senescent_ident, signaling = p)
    if (is.null(net)) return(0) else sum(net$prob)
  })
  
  flow_source_normal <- sapply(pathways, function(p) {
    net <- subsetCommunication(cellchat, sources.use = normal_ident, signaling = p)
    if (is.null(net)) return(0) else sum(net$prob)
  })
  
  # --- 1.2 计算 Target (作为接收者) 的信息流 ---
  flow_target_senescent <- sapply(pathways, function(p) {
    net <- subsetCommunication(cellchat, targets.use = senescent_ident, signaling = p)
    if (is.null(net)) return(0) else sum(net$prob)
  })
  
  flow_target_normal <- sapply(pathways, function(p) {
    net <- subsetCommunication(cellchat, targets.use = normal_ident, signaling = p)
    if (is.null(net)) return(0) else sum(net$prob)
  })
  
  # --- 1.3 合并数据并计算 LogFC ---
  df_combined <- data.frame(
    Pathway = pathways,
    Source_Senescent = flow_source_senescent,
    Source_Normal = flow_source_normal,
    Target_Senescent = flow_target_senescent,
    Target_Normal = flow_target_normal
  ) %>%
    mutate(
      # LogFC 计算
      logFC_Source = log2((Source_Senescent + 1e-6) / (Source_Normal + 1e-6)),
      logFC_Target = log2((Target_Senescent + 1e-6) / (Target_Normal + 1e-6)),
      
      # 定义类型
      Type_Source = case_when(
        logFC_Source >= 0.5  ~ "Ageing-specific",
        logFC_Source <= -0.5 ~ "Normal-specific",
        TRUE                  ~ "Conserved"
      ),
      Type_Target = case_when(
        logFC_Target >= 0.5  ~ "Ageing-specific",
        logFC_Target <= -0.5 ~ "Normal-specific",
        TRUE                  ~ "Conserved"
      )
    )
  
  # --- 1.4 筛选 Ageing-specific 通路 ---
  # 筛选条件：Source或Target中被判定为Ageing-specific，且流值 > 0.05
  target_pathways <- df_combined %>%
    filter(
      (Type_Source == "Ageing-specific" | Type_Target == "Ageing-specific") & 
      (Source_Senescent >= 0.05 | Target_Senescent >= 0.05)
    ) %>%
    pull(Pathway) %>%
    unique()
  
  # 如果没有符合条件的通路，返回一个空图或提示
  if (length(target_pathways) == 0) {
    message(paste("  警告:", cell_type_name, "没有检测到显著的衰老特异性通路。"))
    return(ggplot() + theme_void() + labs(title = paste(cell_type_name, "\n(No Sig. Pathways)")))
  }
  
  # --- 1.5 整理绘图数据 (Long Format) ---
  # 提取 Senescent 数据
  df_senescent <- df_combined %>%
    filter(Pathway %in% target_pathways) %>%
    mutate(InfoFlow = Source_Senescent + Target_Senescent, Condition = "Ageing") %>%
    select(Pathway, InfoFlow, Condition)
  
  # 提取 Normal 数据
  df_normal <- df_combined %>%
    filter(Pathway %in% target_pathways) %>%
    mutate(InfoFlow = Source_Normal + Target_Normal, Condition = "Normal") %>%
    select(Pathway, InfoFlow, Condition)
  
  df_plot <- bind_rows(df_senescent, df_normal)
  
  # --- 1.6 排序 (按总流量排序) ---
  pathway_order <- df_plot %>%
    group_by(Pathway) %>%
    summarise(Total = sum(InfoFlow)) %>%
    arrange(desc(Total)) %>%
    pull(Pathway)
  
  df_plot$Pathway <- factor(df_plot$Pathway, levels = pathway_order)
  
  # --- 1.7 绘图 ---
  p <- ggplot(df_plot, aes(x = Pathway, y = InfoFlow, fill = Condition)) +
    geom_bar(stat = "identity", position = "stack", width = 0.6) +
    scale_fill_manual(values = c("Normal" = "#4DBBD5", "Ageing" = "#E64B35")) +
    labs(
      title = cell_type_name, 
      y = NULL, 
      x = NULL
    ) +
    theme_minimal() +
    theme(
      axis.text.x = element_text(angle = 45, hjust = 1, size = 9, color = "black"),
      axis.line.x = element_line(color = "black", linewidth = 0.3),
      plot.title = element_text(hjust = 0.5, face = "bold", size = 12),
      panel.grid.major.x = element_blank(),
      panel.grid.minor = element_blank(),
      legend.position = "none", # 默认隐藏图例，最后合并时加
      plot.background = element_rect(color = "black", linewidth = 0.5) # 加黑框
    )
  return(p)
}


