Idents(ad_data) <- "cell_groups"

print("抽样前的细胞数量：")
print(table(Idents(ad_data)))

# ==============================================================================
# 优化版：先拆分样本，再独立抽样 (Downsample per Sample)
# ==============================================================================

# ... (前面的加载包、定义 AST_Sen/Nor 分组代码不变) ...

# 1. 按 Library 拆分大对象 (此时尚未抽样)
print("正在按 Library 拆分对象...")
seurat_list <- SplitObject(ad_data, split.by = "library")

# 2. 释放大对象内存 (关键！防止内存溢出)
rm(ad_data)
gc()

# 3. 循环处理每个样本：独立抽样 + 计算 CellChat
for (sample_name in names(seurat_list)) {
  
  file_path <- file.path(save_dir, paste0(sample_name, "_cellchat.rds"))
  if (file.exists(file_path)) next
  
  print(paste("=== 处理样本:", sample_name, "==="))
  obj <- seurat_list[[sample_name]]
  
  # --- 3.1 独立抽样 (关键修改) ---
  # 对当前样本，每种细胞类型 (如 AST_Sen) 最多保留 500 个
  # 为什么是 500？因为单样本内 500 个细胞足够算准通讯概率了，且速度快
  # 如果你的电脑内存够大，可以改回 1000
  print(paste("  -> 正在抽样 (Max 500 cells per group)..."))
  
  # 注意：subset 可能因为某组细胞不足 500 而保留所有细胞，这是正常的
  obj <- subset(obj, downsample = 500)
  
  # 再次检查细胞数，防止抽样后某组细胞太少
  # 如果总细胞数少于 50，跳过该样本
  if (ncol(obj) < 50) {
    print("  -> 细胞数过少，跳过")
    next
  }
  
  tryCatch({
    # --- 3.2 计算 CellChat ---
    # 使用 truncatedMean 方法加速
    cellchat <- createCellChat(object = obj, group.by = "ident", assay = "RNA")
    cellchat@DB <- CellChatDB
    
    cellchat <- subsetData(cellchat)
    cellchat <- identifyOverExpressedGenes(cellchat)
    cellchat <- identifyOverExpressedInteractions(cellchat)
    
    # trim = 0.1 进一步加速并提高稳健性
    cellchat <- computeCommunProb(cellchat, raw.use = TRUE, type = "truncatedMean", trim = 0.1)
    
    # 过滤掉细胞数少于 10 的通讯 (由于已经保证了抽样基数，这里可以用 10)
    cellchat <- filterCommunication(cellchat, min.cells = 10)
    
    cellchat <- computeCommunProbPathway(cellchat)
    cellchat <- aggregateNet(cellchat)
    
    saveRDS(cellchat, file = file_path)
    print(paste("  -> 已保存"))
    
  }, error = function(e) {
    print(paste("  -> 错误:", e))
  })
  
  # 处理完一个样本后，手动清理内存
  rm(obj, cellchat)
  gc()
}

