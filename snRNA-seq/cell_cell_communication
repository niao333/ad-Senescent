# 确保 sample_names 已定义（例如从 cellchat_list 获取）
# sample_names <- names(cellchat_list)

# ==============================================================================
# 3. 定义分析并单独保存图片的函数
# ==============================================================================
analyze_and_save_pairs <- function(target_pairs_list, group_name, output_dir = ".") {
  
  # 如果输出目录不存在则创建
  if (!dir.exists(output_dir)) dir.create(output_dir, recursive = TRUE)
  
  for (k in 1:length(target_pairs_list)) {
    pair <- target_pairs_list[[k]]
    
    # 动态构建细胞名称
    src_sen_name <- get_cell_name(pair$source_type, "Senescent")
    tar_sen_name <- get_cell_name(pair$target_type, "Senescent")
    src_nor_name <- get_cell_name(pair$source_type, "Normal")
    tar_nor_name <- get_cell_name(pair$target_type, "Normal")
    
    message(paste0("\n>>> [", group_name, "] 分析第 ", k, " 对: ", pair$ligand, "-", pair$receptor))
    message(paste0("    对比: ", src_sen_name, "->", tar_sen_name, "  VS  ", src_nor_name, "->", tar_nor_name))
    
    sen_probs <- c()
    nor_probs <- c()
    valid_samples <- c()
    
    for (sample_name in sample_names) {
      cellchat_obj <- cellchat_list[[sample_name]]
      df.net <- subsetCommunication(cellchat_obj)
      
      if (is.null(df.net)) {
        sen_probs <- c(sen_probs, 0)
        nor_probs <- c(nor_probs, 0)
        valid_samples <- c(valid_samples, sample_name)
        next
      }
      
      prob_s <- df.net %>% 
        filter(source == src_sen_name, target == tar_sen_name, 
               ligand == pair$ligand, receptor == pair$receptor) %>%
        pull(prob)
      if(length(prob_s) == 0) prob_s <- 0
      
      prob_n <- df.net %>% 
        filter(source == src_nor_name, target == tar_nor_name, 
               ligand == pair$ligand, receptor == pair$receptor) %>%
        pull(prob)
      if(length(prob_n) == 0) prob_n <- 0
      
      sen_probs <- c(sen_probs, prob_s[1])
      nor_probs <- c(nor_probs, prob_n[1])
      valid_samples <- c(valid_samples, sample_name)
    }
    
    results_df <- data.frame(
      Sample = valid_samples,
      Senescent = sen_probs,
      Normal = nor_probs
    )
    
    results_long <- pivot_longer(results_df, 
                                 cols = c("Senescent", "Normal"),
                                 names_to = "Condition", 
                                 values_to = "Probability")
    
    results_long$Condition <- factor(results_long$Condition, levels = c("Normal", "Senescent"))
    
    # 生成标题和副标题
    main_title <- paste0(pair$ligand, " - ", pair$receptor)
    sub_title <- paste0(pair$source_type, " \u2192 ", pair$target_type)
    
    p <- ggpaired(results_long, 
                  x = "Condition", 
                  y = "Probability",
                  id = "Sample",
                  color = "Condition", 
                  palette = c("#00AFBB", "#FC4E07"), 
                  line.color = "gray", 
                  line.size = 0.4,
                  point.size = 2,
                  xlab = "") +
      stat_compare_means(paired = TRUE, method = "wilcox.test", 
                         label = "p.format", label.y.npc = "top", vjust = 1) +
      labs(title = main_title,
           subtitle = sub_title,
           y = "Probability") +
      theme(legend.position = "none",
            plot.title = element_text(size = 11, face = "bold", hjust = 0.5),
            plot.subtitle = element_text(size = 9, hjust = 0.5))
    
    # 保存为单独的文件（PNG格式）
    filename <- file.path(output_dir, 
                          paste0(group_name, "_", k, "_", 
                                 pair$ligand, "-", pair$receptor, "_",
                                 pair$source_type, "2", pair$target_type, ".pdf"))
    ggsave(filename, p, width = 6, height = 6, )
    message("    已保存: ", filename)
  }
  
  message("\n所有图片已保存至: ", output_dir)
}


